<ui:UiPage x:Class="Rystrap.UI.Elements.Settings.Pages.BetterModsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:resources="clr-namespace:Rystrap.Resources"
      xmlns:page="clr-namespace:Rystrap.UI.Elements.Settings.Pages"
      xmlns:mods="clr-namespace:Rystrap.Models.Mods"
      xmlns:dmodels="clr-namespace:Rystrap.UI.ViewModels.Settings"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance dmodels:BetterModsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="800" d:DesignWidth="900"
      Title="BetterModsPage">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Better Mods" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8" />

        <!-- Tabs + Search + Buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Content="Cursors" Tag="Cursor" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
                <ui:Button Content="Sounds" Tag="Sound" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
                <ui:Button Content="Textures" Tag="Texture" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
                <ui:Button Content="Fonts" Tag="Font" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
                <ui:Button Content="Animations" Tag="Animation" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
                <ui:Button Content="UI" Tag="UI" Click="OnCategoryClick" Margin="0,0,4,0" Padding="10,4" />
            </StackPanel>
            <ui:Button Grid.Column="1" Content="Apply All" Icon="ArrowSync24" Appearance="Primary"
                       Command="{Binding ApplyModsCommand}" Padding="12,4" />
        </Grid>

        <!-- Mod List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding DisplayedMods}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type mods:ModEntry}">
                        <Border Margin="0,0,0,6" Padding="12" CornerRadius="6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Enable Checkbox -->
                                <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                          Loaded="OnCheckBoxLoaded"
                                          Checked="OnModChecked" Unchecked="OnModChecked" />

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                        <Border Background="{DynamicResource SystemAccentColorDefaultBrush}" CornerRadius="3"
                                                Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}" FontSize="9" Foreground="White" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TargetPath}" FontSize="10" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="10" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="No custom file" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <Binding Path="CustomFilePath" Converter="{x:Static page:FilePathDisplayConverter.Instance}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Browse Button -->
                                <ui:Button Grid.Column="2" Content="Browse" Icon="OpenFolder24" Padding="8,4"
                                           Margin="0,0,8,0" FontSize="11" VerticalAlignment="Center"
                                           Click="OnBrowseClick" Tag="{Binding}" />

                                <!-- Status -->
                                <TextBlock Grid.Column="3" Width="60" TextAlignment="Center" FontSize="11"
                                           VerticalAlignment="Center" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Text" Value="ON" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Bar -->
        <Border Grid.Row="3" Margin="0,8,0,0" Padding="10,8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="0" Content="Enable All" Icon="Checkmark24" Padding="10,4" Margin="0,0,6,0"
                           Command="{Binding EnableAllInCategoryCommand}" />
                <ui:Button Grid.Column="1" Content="Disable All" Icon="Dismiss24" Padding="10,4" Margin="0,0,6,0"
                           Command="{Binding DisableAllInCategoryCommand}" />
                <ui:Button Grid.Column="2" Content="Reset Mods" Icon="ArrowCounterclockwise24" Padding="10,4" Margin="0,0,6,0"
                           Appearance="Danger" Command="{Binding ResetModsCommand}" />
                <ui:Button Grid.Column="3" Content="Export" Icon="ArrowExportRtl24" Padding="10,4" Margin="0,0,6,0"
                           Command="{Binding ExportPackCommand}" />
                <ui:Button Grid.Column="4" Content="Import" Icon="ArrowImport24" Padding="10,4"
                           Command="{Binding ImportPackCommand}" />
                <TextBlock Grid.Column="6" Text="{Binding ModCountText}" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="4" Margin="0,6,0,0" Padding="10,8" CornerRadius="6"
                Visibility="{Binding StatusVisibility}" BorderThickness="1"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource InformationAccentColor}" Opacity="0.15" />
            </Border.Background>
            <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium"
                       Foreground="{Binding StatusForeground}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</ui:UiPage>
