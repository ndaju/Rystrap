<ui:UiPage x:Class="Rystrap.UI.Elements.Settings.Pages.RystrapPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:Rystrap.UI.Elements.Settings.Pages"
      xmlns:controls="clr-namespace:Rystrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:Rystrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Rystrap.Resources"
      d:DataContext="{d:DesignInstance Type=models:RystrapViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="BehaviourPage"
      Scrollable="True">

    <StackPanel Margin="0,0,14,14">
        <TextBlock Margin="0,0,0,8" Text="{x:Static resources:Strings.Menu_Rystrap_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Behaviour_AutoUpdate_Title}"
            Description="{x:Static resources:Strings.Menu_Behaviour_AutoUpdate_Description}">
            <ui:ToggleSwitch IsChecked="{Binding UpdateCheckingEnabled, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl 
            Header="{x:Static resources:Strings.Menu_Rystrap_Analytics_Title}"
            Description="{Binding Source={x:Static resources:Strings.Menu_Rystrap_Analytics_Description}, Converter={StaticResource StringFormatConverter}, ConverterParameter='https://Rystraplabs.com/wiki/info/privacy-policy/'}">
            <ui:ToggleSwitch IsChecked="{Binding AnalyticsEnabled, Mode=TwoWay}" />
        </controls:OptionControl>

        <!-- This does not need i18n as this is locked behind "Developer Mode" -->
        <controls:OptionControl
            Visibility="{Binding Path=WebEnvironmentVisibility, Mode=OneTime}"
            Header="Web environment" 
            Description="Site to use for metrics">
            <ComboBox Width="200" Padding="10,5,10,5" ItemsSource="{Binding WebEnvironments, Mode=OneWay}" SelectedValue="{Binding WebEnvironment, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.Menu_Rystrap_ExportData_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.Menu_Rystrap_ExportData_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" MinWidth="100" Margin="0,0,16,0" Icon="CopySelect20" Content="{x:Static resources:Strings.Common_Export}" Command="{Binding ExportDataCommand}">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ElementName=ShouldExportConfig, Path=IsChecked}" Value="False" />
                                            <Condition Binding="{Binding ElementName=ShouldExportLogs, Path=IsChecked}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="False" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                                <Setter Property="IsEnabled" Value="True" />
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </Grid>
            </ui:CardExpander.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" Name="ShouldExportConfig" Content="{x:Static resources:Strings.Menu_Rystrap_ExportData_ExportConfig}" IsChecked="{Binding ShouldExportConfig}" />
                <CheckBox Grid.Column="1" Name="ShouldExportLogs" Content="{x:Static resources:Strings.Menu_Rystrap_ExportData_ExportLogs}" IsChecked="{Binding ShouldExportLogs}" />
            </Grid>
        </ui:CardExpander>

        <controls:OptionControl
            Header="Import / Export All Settings"
            Description="Backup or restore all settings from a .Rystrap file">
            <StackPanel Orientation="Horizontal">
                <ui:Button Icon="ArrowImport24" Content="Import" Padding="12,4" Command="{Binding ImportSettingsCommand}" />
                <ui:Button Icon="CopySelect20" Content="Export" Padding="12,4" Margin="6,0,0,0" Command="{Binding ExportSettingsCommand}" />
            </StackPanel>
        </controls:OptionControl>

        <Separator Margin="0,4,0,4" />

        <TextBlock Text="Advanced" FontSize="20" FontWeight="Medium" Margin="0,16,0,0" />

        <controls:OptionControl
            Header="Startup Performance Mode"
            Description="Disable non-essential features on launch for faster startup">
            <ui:ToggleSwitch IsChecked="{Binding StartupPerformanceMode, Mode=TwoWay}" />
        </controls:OptionControl>

        <controls:OptionControl
            Header="Proxy Settings"
            Description="Configure a network proxy for Roblox connections">
            <StackPanel Orientation="Horizontal">
                <ui:ToggleSwitch IsChecked="{Binding ProxyEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                <ui:TextBox Text="{Binding ProxyAddress}" Width="150" Margin="8,0,4,0" PlaceholderText="127.0.0.1" IsEnabled="{Binding ProxyEnabled}" />
                <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0" />
                <ui:TextBox Text="{Binding ProxyPort}" Width="60" Margin="4,0,0,0" PlaceholderText="8080" IsEnabled="{Binding ProxyEnabled}" />
            </StackPanel>
        </controls:OptionControl>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="False">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.Uninstaller_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.Uninstaller_Text}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" MinWidth="100" Margin="0,0,16,0" Icon="Delete24" Content="{x:Static resources:Strings.Uninstaller_Uninstall}" Appearance="Danger" Command="{Binding UninstallCommand}" />
                </Grid>
            </ui:CardExpander.Header>
        </ui:CardExpander>
    </StackPanel>
</ui:UiPage>
