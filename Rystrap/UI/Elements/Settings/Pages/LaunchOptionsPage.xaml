<ui:UiPage x:Class="Rystrap.UI.Elements.Settings.Pages.LaunchOptionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Rystrap.UI.Elements.Controls"
      xmlns:models="clr-namespace:Rystrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Rystrap.Resources"
      d:DataContext="{d:DesignInstance Type=models:LaunchOptionsViewModel}"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="LaunchOptionsPage"
      Scrollable="True">
    <StackPanel Margin="0,0,14,14">
        <TextBlock Margin="0,0,0,8" Text="{x:Static resources:Strings.LaunchOptions_Description}" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.LaunchOptions_CustomArgs_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.LaunchOptions_CustomArgs_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>
            <StackPanel>
                <ui:TextBox Text="{Binding CustomLaunchArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="-xdx -allow2 -d3d11" />
                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" Text="{x:Static resources:Strings.LaunchOptions_CustomArgs_Hint}" />
            </StackPanel>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.LaunchOptions_MemoryLimit_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.LaunchOptions_MemoryLimit_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" Minimum="0" Maximum="16384" TickFrequency="256" IsSnapToTickEnabled="True"
                            Value="{Binding MemoryLimitMB, Mode=TwoWay}" />
                    <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding MemoryLimitDisplay, Mode=OneWay}" FontWeight="SemiBold" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.LaunchOptions_GpuPreference_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.LaunchOptions_GpuPreference_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>
            <ComboBox Width="200" Padding="10,5,10,5" ItemsSource="{Binding GpuPreferences, Mode=OneTime}" SelectedValue="{Binding GpuPreference, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </ui:CardExpander>

        <controls:OptionControl
            Header="{x:Static resources:Strings.LaunchOptions_MultiInstance_Title}"
            Description="{x:Static resources:Strings.LaunchOptions_MultiInstance_Description}">
            <ui:ToggleSwitch IsChecked="{Binding MultiInstanceEnabled, Mode=TwoWay}" />
        </controls:OptionControl>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.LaunchOptions_WorkingDirectory_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.LaunchOptions_WorkingDirectory_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0" Margin="0,0,8,0" Text="{Binding WorkingDirectory, Mode=TwoWay}" PlaceholderText="C:\Roblox" />
                <ui:Button Grid.Column="1" Height="35" Icon="Folder24" Content="{x:Static resources:Strings.Common_Browse}" Command="{Binding BrowseWorkingDirectoryCommand}" />
            </Grid>
        </ui:CardExpander>

        <ui:CardExpander Margin="0,8,0,0" IsExpanded="True">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock FontSize="14" Text="{x:Static resources:Strings.LaunchOptions_EnvOverrides_Title}" />
                        <TextBlock FontSize="12" Text="{x:Static resources:Strings.LaunchOptions_EnvOverrides_Description}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </ui:CardExpander.Header>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ListBox Grid.Row="0" Grid.Column="0" Height="180" Margin="0,0,4,0"
                         ItemsSource="{Binding EnvironmentOverrides, Mode=OneWay}"
                         SelectedIndex="{Binding SelectedEnvOverrideIndex, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Name, Mode=OneWay}" />
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Text="{Binding Value, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Top">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" Text="{x:Static resources:Strings.LaunchOptions_Name}" />
                    <ui:TextBox IsEnabled="{Binding IsEnvOverrideSelected, Mode=OneWay}"
                               Text="{Binding SelectedEnvOverride.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,8,0,4" Text="{x:Static resources:Strings.LaunchOptions_Value}" />
                    <ui:TextBox IsEnabled="{Binding IsEnvOverrideSelected, Mode=OneWay}"
                               Text="{Binding SelectedEnvOverride.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Margin="0,0,8,0" Icon="Add28" Content="{x:Static resources:Strings.Common_Add}" Command="{Binding AddEnvironmentOverrideCommand}" />
                    <ui:Button Icon="Delete28" Content="{x:Static resources:Strings.Common_Remove}" Appearance="Danger"
                              IsEnabled="{Binding IsEnvOverrideSelected, Mode=OneWay}" Command="{Binding RemoveEnvironmentOverrideCommand}" />
                </StackPanel>
            </Grid>
        </ui:CardExpander>

        <ui:Card Margin="0,12,0,0" Padding="12">
            <StackPanel>
                <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static resources:Strings.LaunchOptions_Preview}" Margin="0,0,0,4" />
                <ui:TextBox IsReadOnly="True" Text="{Binding PreviewCommandLine, Mode=OneWay}" FontFamily="Consolas" FontSize="12" />
            </StackPanel>
        </ui:Card>

        <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Icon="ArrowReset24" Content="{x:Static resources:Strings.LaunchOptions_ResetDefaults}" Command="{Binding ResetDefaultsCommand}" Margin="0,0,8,0" />
        </StackPanel>

        <Separator Margin="0,4,0,8" />

        <TextBlock Text="Utility" FontSize="20" FontWeight="Medium" Margin="0,16,0,0" />

        <controls:OptionControl Header="Screenshots Folder" Description="Open the Roblox screenshots folder in File Explorer">
            <ui:Button Content="Open Folder" Padding="12,4" Command="{Binding OpenScreenshotsFolderCommand}" />
        </controls:OptionControl>
    </StackPanel>
</ui:UiPage>
