<ui:UiPage x:Class="Rystrap.UI.Elements.Settings.Pages.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Rystrap.UI.Elements.Controls"
      xmlns:dmodels="clr-namespace:Rystrap.UI.ViewModels.Settings"
      xmlns:resources="clr-namespace:Rystrap.Resources"
      xmlns:converters="clr-namespace:Rystrap.UI.Converters"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance dmodels:AccountsViewModel, IsDesignTimeCreatable=True}"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="AccountsPage"
      Scrollable="True">
    <ui:UiPage.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </ui:UiPage.Resources>
    <StackPanel Margin="0,0,14,14">
        <TextBlock Text="Manage multiple Roblox accounts. Add accounts with your .ROBLOSECURITY cookie for quick login and switching." FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
        <TextBlock Margin="0,2,0,0" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap">
            <Run Text="Your cookie never leaves your device. Rystrap is open source — you can verify this yourself at" />
            <Hyperlink NavigateUri="https://github.com/ndaju/Rystrap" RequestNavigate="Hyperlink_RequestNavigate">github.com/ndaju/Rystrap</Hyperlink>
            <Run Text="." />
        </TextBlock>

        <!-- Toolbar -->
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Saved Accounts" FontSize="20" FontWeight="Medium" />
                <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Content="Add" Icon="Add28" Padding="8,4" Margin="2,0" Command="{Binding AddAccountCommand}" />
                <ui:Button Content="Duplicate" Icon="CopySelect20" Padding="8,4" Margin="2,0" IsEnabled="{Binding HasSelection}" Command="{Binding DuplicateAccountCommand}" />
                <ui:Button Content="Remove" Icon="Delete28" Padding="8,4" Margin="2,0" Appearance="Danger" IsEnabled="{Binding HasSelection}" Command="{Binding RemoveAccountCommand}" />
                <ui:Button Content="Import" Icon="ArrowImport24" Padding="8,4" Margin="2,0" Command="{Binding ImportAccountsCommand}" />
                <ui:Button Content="Export" Icon="ArrowExportRtl24" Padding="8,4" Margin="2,0" Command="{Binding ExportAccountsCommand}" />
            </StackPanel>
        </Grid>

        <!-- Main layout: list + editor -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Account list -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="4" Margin="0,0,8,0">
                <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount, Mode=TwoWay}" BorderThickness="0" Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,2" Padding="8" CornerRadius="4" 
                                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1"
                                    Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Avatar or initial -->
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}" Margin="0,0,8,0" ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="{Binding Initial}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"
                                                           Visibility="{Binding HasAvatar, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                <Image Source="{Binding AvatarPath}" Width="36" Height="36" Stretch="UniformToFill"
                                                       Visibility="{Binding HasAvatar, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding RobloxUsername}" FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" MouseDown="Star_MouseDown" Cursor="Hand">
                                            <TextBlock Text="★" FontSize="18" Foreground="Gold"
                                                       Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <TextBlock Text="☆" FontSize="18" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Visibility="{Binding IsFavorite, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

            <!-- Editor panel -->
            <Border Grid.Column="1" BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12" IsEnabled="{Binding HasSelection}">
                <StackPanel>
                    <TextBlock Text="Account Details" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Edit the selected account details below" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,8" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Display Name" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" PlaceholderText="e.g. My Alt" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Roblox Username" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditRobloxUsername, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" PlaceholderText="e.g. coolplayer123" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text=".ROBLOSECURITY" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditRobloxCookie, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4" PlaceholderText="Paste your .ROBLOSECURITY cookie here" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Volume" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,4">
                            <Slider Minimum="0" Maximum="100" Value="{Binding EditVolume}" Width="160" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding EditVolume, StringFormat='{}{0}%'}" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13" />
                        </StackPanel>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes" VerticalAlignment="Top" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,4" />
                    </Grid>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Save Changes" Icon="Checkmark24" Padding="12,4" Margin="0,0,4,0" Command="{Binding SaveSelectedCommand}" />
                        <ui:Button Content="Fetch Avatar" Padding="12,4" Margin="4,0" Command="{Binding FetchAvatarCommand}" IsEnabled="{Binding CanFetchAvatar}" />
                    </StackPanel>

                    <!-- Reorder -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="▲ Move Up" Padding="8,4" Margin="0,0,4,0" Command="{Binding MoveUpCommand}" />
                        <ui:Button Content="▼ Move Down" Padding="8,4" Margin="4,0,0,0" Command="{Binding MoveDownCommand}" />
                    </StackPanel>

                    <!-- Quick Switch -->
                    <Separator Margin="0,8,0,4" />
                    <TextBlock Text="Quick Switch" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="Launch Roblox with the selected account" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,4" />
                    <ui:Button Content="Launch with Selected Account" Icon="Play24" Padding="12,4" HorizontalAlignment="Left" Command="{Binding QuickSwitchCommand}" IsEnabled="{Binding HasSelection}" />
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</ui:UiPage>
