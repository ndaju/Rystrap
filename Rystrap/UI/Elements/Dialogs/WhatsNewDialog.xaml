<base:WpfUiWindow x:Class="Rystrap.UI.Elements.Dialogs.WhatsNewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
        xmlns:resources="clr-namespace:Rystrap.Resources"
        mc:Ignorable="d"
        Title="What's New in Rystrap"
        Width="520"
        Height="480"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="What's New" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1">
            <TextBlock x:Name="ChangelogText" TextWrapping="Wrap" FontSize="14" />
        </ScrollViewer>

        <ui:Button Grid.Row="2" Content="Got it!" HorizontalAlignment="Right" Margin="0,16,0,0" Click="GotIt_Click" />
    </Grid>
</base:WpfUiWindow>
