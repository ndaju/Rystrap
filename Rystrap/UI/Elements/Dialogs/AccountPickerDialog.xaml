<base:WpfUiWindow x:Class="Rystrap.UI.Elements.Dialogs.AccountPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
        xmlns:converters="clr-namespace:Rystrap.UI.Converters"
        mc:Ignorable="d"
        Title="Select Account"
        MinWidth="0"
        MinHeight="0"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">
    <base:WpfUiWindow.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </base:WpfUiWindow.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Choose an Account" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="Select which Roblox account to use." FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="AccountListBox" MinHeight="200" MaxHeight="400"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" SelectionMode="Single">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8" CornerRadius="4" BorderThickness="0" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" 
                                    Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}" Margin="0,0,8,0" ClipToBounds="True">
                                <Grid>
                                    <TextBlock Text="{Binding Initial}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                                               Visibility="{Binding HasAvatar, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <Image Source="{Binding AvatarPath}" Width="32" Height="32" Stretch="UniformToFill"
                                           Visibility="{Binding HasAvatar, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="{Binding RobloxUsername}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="★" FontSize="16" Foreground="Gold" VerticalAlignment="Center" Margin="4,0,0,0"
                                       Visibility="{Binding IsFavorite, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button x:Name="SkipButton" Content="Continue without account" Margin="0,0,8,0" Padding="12,6" Click="SkipButton_Click" />
            <ui:Button x:Name="SelectButton" Content="Select" Appearance="Primary" Padding="12,6" IsEnabled="False" Click="SelectButton_Click" />
        </StackPanel>
    </Grid>
</base:WpfUiWindow>
