<base:WpfUiWindow x:Class="Rystrap.UI.Elements.Dialogs.GameSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
        mc:Ignorable="d"
        Title="Game-Specific Settings"
        MinWidth="0"
        MinHeight="0"
        Width="750"
        Height="500"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Game-Specific Settings" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding EntryCount}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="GameSettingsListView" BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ItemsSource="{Binding Entries}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Place Name" Width="180" DisplayMemberBinding="{Binding PlaceName}" />
                        <GridViewColumn Header="Place ID" Width="100" DisplayMemberBinding="{Binding PlaceId}" />
                        <GridViewColumn Header="Graphics" Width="80" DisplayMemberBinding="{Binding GraphicsQuality}" />
                        <GridViewColumn Header="FPS Cap" Width="80" DisplayMemberBinding="{Binding FpsCap}" />
                        <GridViewColumn Header="Render Dist." Width="90" DisplayMemberBinding="{Binding RenderDistance}" />
                        <GridViewColumn Header="No Particles" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding DisableParticles}" IsEnabled="False" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="No Lighting" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding DisableLighting}" IsEnabled="False" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="Close" Appearance="Primary" Padding="16,6" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</base:WpfUiWindow>
