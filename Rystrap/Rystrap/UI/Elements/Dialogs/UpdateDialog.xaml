<base:WpfUiWindow x:Class="Rystrap.UI.Elements.Dialogs.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
        xmlns:dmodels="clr-namespace:Rystrap.UI.ViewModels.Dialogs"
        xmlns:resources="clr-namespace:Rystrap.Resources"
        xmlns:controls="clr-namespace:Rystrap.UI.Elements.Controls"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance dmodels:UpdateViewModel, IsDesignTimeCreatable=True}"
        Title="Rystrap"
        MinWidth="0"
        MinHeight="0"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        Closing="WpfUiWindow_Closing"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Grid.ColumnSpan="2" Padding="8" Title="Rystrap" ShowMinimize="False" ShowMaximize="False" CanMaximize="False" KeyboardNavigation.TabNavigation="None" Icon="pack://application:,,,/Rystrap.ico" />

        <StackPanel Grid.Row="1" Margin="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Title, Mode=OneWay}" Margin="0,0,0,4" />
            <TextBlock FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap">
                <Run Text="{x:Static resources:Strings.Update_CurrentVersion}" />
                <Run Text="{Binding CurrentVersion, Mode=OneWay}" />
                <Run Text=" → " />
                <Run Text="{Binding LatestVersion, Mode=OneWay}" />
            </TextBlock>

            <ui:Card Margin="0,12,0,0" Padding="12"
                     Visibility="{Binding ShowChangelog, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <controls:MarkdownTextBlock FontSize="13" MarkdownText="{Binding Changelog, Mode=OneWay}" TextWrapping="Wrap" />
                </ScrollViewer>
            </ui:Card>

            <StackPanel Margin="0,12,0,0"
                        Visibility="{Binding ShowProgress, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Height="6" Minimum="0" Maximum="100" Value="{Binding DownloadProgress, Mode=OneWay}" />
                <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding StatusText, Mode=OneWay}" />
            </StackPanel>

            <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding StatusText, Mode=OneWay}"
                       Visibility="{Binding IsChecking, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Border Grid.Row="2" Margin="0,10,0,0" Padding="15" Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" FlowDirection="LeftToRight" HorizontalAlignment="Right">
                    <Button MinWidth="100" Content="{x:Static resources:Strings.Update_InstallNow}"
                            Command="{Binding UpdateNowCommand}"
                            IsEnabled="{Binding HasUpdate, Mode=OneWay}"
                            Visibility="{Binding IsDownloading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button MinWidth="100" Margin="8,0,0,0" Content="{Binding SkipVersionText, Mode=OneWay}"
                            Command="{Binding SkipVersionCommand}"
                            IsEnabled="{Binding HasUpdate, Mode=OneWay}"
                            Visibility="{Binding IsDownloading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button MinWidth="100" Margin="8,0,0,0" Content="{x:Static resources:Strings.Update_RemindLater}"
                            Command="{Binding RemindLaterCommand}"
                            Visibility="{Binding IsDownloading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                    <Button MinWidth="100" Content="{x:Static resources:Strings.Common_Cancel}"
                            IsCancel="True"
                            Visibility="{Binding IsDownloading, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>
