<base:WpfUiWindow
    x:Class="Rystrap.UI.Elements.Dialogs.ThemeManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:Rystrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Rystrap.UI.ViewModels.Dialogs"
    Title="Theme Manager"
    Width="720"
    MinHeight="500"
    d:DataContext="{d:DesignInstance viewmodels:ThemeManagerViewModel, IsDesignTimeCreatable=True}"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="CanResizeWithGrip"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Theme Manager"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Padding="8"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Theme list -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListBox
                    x:Name="ThemeListBox"
                    Grid.Row="0"
                    ItemsSource="{Binding Themes}"
                    SelectedItem="{Binding SelectedTheme}"
                    DisplayMemberPath="Metadata.Name"
                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="4">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListAccentLowBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Grid Grid.Row="1" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:TextBox
                        Grid.Column="0"
                        Margin="0,0,4,0"
                        PlaceholderText="New theme name..."
                        Text="{Binding NewThemeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <ui:Button
                        Grid.Column="1"
                        Icon="Add28"
                        Content="Create"
                        Command="{Binding CreateThemeCommand}" />
                </Grid>
            </Grid>

            <!-- Preview area -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Margin="0,0,0,8"
                    Text="{Binding SelectedTheme.Metadata.Name, FallbackValue='Select a theme'}" />

                <!-- Theme preview mockup -->
                <Border
                    Grid.Row="1"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                    Background="{Binding PreviewWindowBackground}"
                    Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Title bar mockup -->
                        <Border Grid.Row="0" Background="{Binding PreviewWindowBackground}">
                            <Grid Margin="8,0">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{Binding PreviewWindowForeground}"
                                    Text="Theme Preview" />
                            </Grid>
                        </Border>

                        <!-- Content mockup -->
                        <StackPanel Grid.Row="1" Margin="12">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{Binding PreviewWindowForeground}"
                                Text="Preview Window" />

                            <Border
                                Margin="0,8,0,0"
                                Background="{Binding PreviewCardBackground}"
                                CornerRadius="6"
                                Padding="10">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{Binding PreviewWindowForeground}"
                                        Text="Sample card content" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontSize="10"
                                        Foreground="{Binding PreviewWindowForeground}" Opacity="0.6"
                                        Text="Secondary text goes here" />
                                </StackPanel>
                            </Border>

                            <Button
                                Margin="0,10,0,0"
                                Background="{Binding PreviewButtonBackground}"
                                Foreground="{Binding PreviewButtonForeground}"
                                Padding="16,6"
                                Content="Sample Button"
                                HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Status bar mockup -->
                        <Border Grid.Row="2" Padding="8,4" Background="{Binding PreviewCardBackground}">
                            <TextBlock
                                FontSize="10"
                                Foreground="{Binding PreviewWindowForeground}" Opacity="0.5"
                                Text="Status bar" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Description -->
                <TextBlock
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{Binding PreviewDescription}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Bottom"
                    MaxHeight="60" />
            </Grid>
        </Grid>

        <!-- Status bar -->
        <TextBlock
            Grid.Row="2"
            Margin="16,8,16,0"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{Binding StatusMessage}"
            TextWrapping="Wrap"
            Visibility="{Binding StatusVisibility}" />

        <!-- Bottom buttons -->
        <Border
            Grid.Row="3"
            Margin="0,10,0,0"
            Padding="15"
            Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <Grid>
                <StackPanel
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">
                    <ui:Button
                        MinWidth="100"
                        Icon="ArrowImport24"
                        Content="Import"
                        Command="{Binding ImportThemeCommand}" />
                    <ui:Button
                        MinWidth="100"
                        Margin="8,0,0,0"
                        Icon="ArrowExport24"
                        Content="Export"
                        Command="{Binding ExportThemeCommand}"
                        IsEnabled="{Binding HasSelectedTheme}" />
                    <ui:Button
                        MinWidth="100"
                        Margin="8,0,0,0"
                        Icon="Delete28"
                        Content="Delete"
                        Appearance="Danger"
                        Command="{Binding DeleteThemeCommand}"
                        IsEnabled="{Binding CanDelete}" />
                </StackPanel>

                <StackPanel
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        MinWidth="100"
                        Click="OnApplyClicked"
                        Content="Apply" />
                    <Button
                        MinWidth="100"
                        Margin="12,0,0,0"
                        Content="{x:Static resources:Strings.Common_Cancel}"
                        IsCancel="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>
