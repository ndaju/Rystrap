<base:WpfUiWindow
    x:Class="Rystrap.UI.Elements.Dialogs.ModManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:Rystrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Rystrap.UI.ViewModels.Dialogs"
    Title="Mod Manager"
    Width="780"
    MinHeight="550"
    d:DataContext="{d:DesignInstance viewmodels:ModManagerViewModel, IsDesignTimeCreatable=True}"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="CanResizeWithGrip"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Mod Manager"
            Grid.Row="0"
            Padding="8"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0">
                <!-- Mods Tab -->
                <TabItem Header="Mods">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="280" />
                        </Grid.ColumnDefinitions>

                        <!-- Mod list -->
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Category filter -->
                            <ComboBox
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Padding="8,4"
                                Width="200"
                                HorizontalAlignment="Left"
                                ItemsSource="{Binding Categories}"
                                SelectedItem="{Binding SelectedCategory}"
                                SelectionChanged="OnCategoryChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=., Converter={StaticResource EnumNameConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <!-- Mod list -->
                            <ListBox
                                Grid.Row="1"
                                ItemsSource="{Binding Mods}"
                                SelectedItem="{Binding SelectedMod}"
                                BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox
                                                Grid.Column="0"
                                                IsChecked="{Binding IsEnabled}"
                                                VerticalAlignment="Center"
                                                IsHitTestVisible="False" />
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                                    <Run Text="{Binding Category, Mode=OneWay}" />
                                                    <Run Text=" - " />
                                                    <Run Text="{Binding Author, Mode=OneWay, TargetNullValue='Unknown'}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="2"
                                                FontSize="10"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                VerticalAlignment="Center"
                                                Text="{Binding Version, Mode=OneWay}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- Mod details & actions -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Details -->
                            <Border
                                Grid.Row="0"
                                Margin="0,0,0,8"
                                Padding="10"
                                CornerRadius="6"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                                <Grid>
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding ModDetails, Mode=OneWay}"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Top" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="Select a mod to view details"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedMod}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Actions -->
                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <ui:Button
                                    HorizontalAlignment="Stretch"
                                    Icon="Add28"
                                    Content="Add Mod"
                                    Margin="0,0,0,4"
                                    Command="{Binding AddModCommand}" />
                                <ui:Button
                                    HorizontalAlignment="Stretch"
                                    Icon="ArrowImport24"
                                    Content="Import Mod Pack"
                                    Margin="0,0,0,4"
                                    Command="{Binding ImportModPackCommand}" />
                                <ui:Button
                                    HorizontalAlignment="Stretch"
                                    Icon="Folder24"
                                    Content="Open Mods Folder"
                                    Margin="0,0,0,4"
                                    Command="{Binding OpenModsFolderCommand}" />
                            </StackPanel>

                            <!-- Toggle actions -->
                            <StackPanel Grid.Row="2">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ui:Button
                                        Grid.Column="0"
                                        Margin="0,0,4,0"
                                        HorizontalAlignment="Stretch"
                                        Icon="Checkmark24"
                                        Content="Enable All"
                                        Command="{Binding EnableAllCommand}" />
                                    <ui:Button
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        Icon="Dismiss24"
                                        Content="Disable All"
                                        Appearance="Danger"
                                        Command="{Binding DisableAllCommand}" />
                                </Grid>
                                <ui:Button
                                    HorizontalAlignment="Stretch"
                                    Icon="ArrowSync24"
                                    Content="Detect Conflicts"
                                    Command="{Binding DetectConflictsCommand}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Presets Tab -->
                <TabItem Header="Presets">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <!-- Preset list -->
                        <ListBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding Presets}"
                            SelectedItem="{Binding SelectedPreset}"
                            DisplayMemberPath="Name"
                            BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13" />
                                        <TextBlock
                                            Grid.Row="1"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding Description}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Preset actions -->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="Create Preset" />

                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Name" />
                            <ui:TextBox
                                Margin="0,4,0,8"
                                PlaceholderText="Preset name..."
                                Text="{Binding NewPresetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Description" />
                            <ui:TextBox
                                Margin="0,4,0,8"
                                PlaceholderText="Optional description..."
                                Text="{Binding NewPresetDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <ui:Button
                                Margin="0,0,0,8"
                                HorizontalAlignment="Stretch"
                                Icon="Save24"
                                Content="Create Preset"
                                Command="{Binding CreatePresetCommand}" />

                            <Separator Margin="0,8,0,8" />

                            <ui:Button
                                Margin="0,0,0,4"
                                HorizontalAlignment="Stretch"
                                Icon="ArrowDownload24"
                                Content="Load Preset"
                                Command="{Binding LoadPresetCommand}"
                                IsEnabled="{Binding HasSelectedPreset}" />
                            <ui:Button
                                HorizontalAlignment="Stretch"
                                Icon="Delete28"
                                Content="Delete Preset"
                                Appearance="Danger"
                                Command="{Binding DeletePresetCommand}"
                                IsEnabled="{Binding HasSelectedPreset}" />
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Conflicts Tab -->
                <TabItem Header="Conflicts">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            Text="{Binding ConflictStatus}" />

                        <ListBox
                            Grid.Row="1"
                            ItemsSource="{Binding Conflicts}"
                            BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Padding="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontSize="13">
                                            <Run Text="{Binding ModA.Name, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" conflicts with " />
                                            <Run Text="{Binding ModB.Name, Mode=OneWay}" FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock
                                            Grid.Row="1"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Text="{Binding Reason}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status -->
        <TextBlock
            Grid.Row="2"
            Margin="16,8,16,0"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{Binding StatusMessage}"
            TextWrapping="Wrap"
            Visibility="{Binding StatusVisibility}" />

        <!-- Bottom buttons -->
        <Border
            Grid.Row="3"
            Margin="0,10,0,0"
            Padding="15"
            Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel
                HorizontalAlignment="Right"
                FlowDirection="LeftToRight"
                Orientation="Horizontal">
                <Button
                    MinWidth="100"
                    Click="OnRefreshClicked"
                    Content="Refresh" />
                <Button
                    MinWidth="100"
                    Margin="12,0,0,0"
                    Content="{x:Static resources:Strings.Common_Cancel}"
                    IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</base:WpfUiWindow>
