<base:WpfUiWindow
    x:Class="Rystrap.UI.Elements.Dialogs.ImportModPackDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="clr-namespace:Rystrap.Resources"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodels="clr-namespace:Rystrap.UI.ViewModels.Dialogs"
    Title="Import Mod Pack"
    Width="520"
    MinHeight="400"
    d:DataContext="{d:DesignInstance viewmodels:ImportModPackViewModel, IsDesignTimeCreatable=True}"
    Background="{ui:ThemeResource ApplicationBackgroundBrush}"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Title="Import Mod Pack"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Padding="8"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False" />

        <!-- Pack Info -->
        <Grid Grid.Row="1" Margin="20,16,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Pack Title -->
            <TextBlock Grid.Row="0" Text="{Binding PackTitle}" FontSize="22" FontWeight="SemiBold"
                       TextWrapping="Wrap" />

            <!-- Author and Version -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                <Border Background="{DynamicResource SystemAccentColorDefaultBrush}" CornerRadius="4"
                        Padding="8,3" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Author}" FontSize="12" Foreground="White" FontWeight="SemiBold" />
                </Border>
                <Border Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}" CornerRadius="4"
                        Padding="8,3">
                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Border>
            </StackPanel>

            <!-- Description -->
            <TextBlock Grid.Row="2" Text="{Binding PackDescription}" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"
                       Margin="0,10,0,0" />

            <!-- Created Date -->
            <TextBlock Grid.Row="3" FontSize="11" Margin="0,8,0,0"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                <Run Text="Created: " />
                <Run Text="{Binding CreatedDate, Mode=OneWay}" />
            </TextBlock>

            <!-- Mod Count -->
            <TextBlock Grid.Row="4" FontSize="12" Margin="0,12,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="SemiBold">
                <Run Text="{Binding ModCount, Mode=OneWay}" />
                <Run Text=" mod(s) included" />
            </TextBlock>

            <!-- Mods List -->
            <Border Grid.Row="5" Margin="0,10,0,0" Padding="0"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                    <ItemsControl ItemsSource="{Binding Mods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Category Icon -->
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Category}" FontSize="9" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                        </Border>

                                        <!-- Mod Name and Description -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <!-- Enabled Checkbox -->
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                                  VerticalAlignment="Center" IsHitTestVisible="True">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.CustomizeMode, RelativeSource={RelativeSource AncestorType=base:WpfUiWindow}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Message -->
        <TextBlock Grid.Row="2" Margin="20,8,20,0" FontSize="12"
                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                   Text="{Binding StatusMessage}" TextWrapping="Wrap"
                   Visibility="{Binding StatusVisibility}" />

        <!-- Bottom Buttons -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="15"
                Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding StatusText}" />

                <ui:Button Grid.Column="1" Margin="8,0,0,0" Padding="12,6"
                           Content="Customize" Icon="Settings24"
                           Command="{Binding CustomizeCommand}"
                           Visibility="{Binding IsCustomizeVisible}" />

                <ui:Button Grid.Column="2" Margin="8,0,0,0" Padding="16,6"
                           Content="Install All" Icon="ArrowDownload24"
                           Appearance="Primary"
                           Command="{Binding InstallAllCommand}" />

                <Button Grid.Column="3" Margin="8,0,0,0" MinWidth="80"
                        Content="{x:Static resources:Strings.Common_Cancel}"
                        IsCancel="True" Click="OnCancelButtonClicked" />
            </Grid>
        </Border>
    </Grid>
</base:WpfUiWindow>
