<base:WpfUiWindow x:Class="Rystrap.UI.Elements.Dialogs.LogViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Rystrap.UI.Elements.Dialogs"
        xmlns:base="clr-namespace:Rystrap.UI.Elements.Base"
        mc:Ignorable="d"
        Title="Roblox Log Viewer"
        MinWidth="0"
        MinHeight="0"
        Width="750"
        Height="550"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Roblox Console Logs" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrongStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
            <ListView x:Name="LogListView" BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ItemsSource="{Binding LogFiles}"
                      SelectionMode="Single"
                      MouseDoubleClick="LogListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="File Name" Width="280" DisplayMemberBinding="{Binding FileName}" />
                        <GridViewColumn Header="Last Modified" Width="160" DisplayMemberBinding="{Binding LastModified}" />
                        <GridViewColumn Header="Size (KB)" Width="100" DisplayMemberBinding="{Binding SizeKB}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button x:Name="OpenButton" Content="Open Selected" Icon="DocumentSearch24" Padding="12,6" Margin="0,0,8,0" IsEnabled="False" Click="OpenButton_Click" />
            <ui:Button x:Name="ClearButton" Content="Clear All Logs" Icon="Delete28" Padding="12,6" Margin="0,0,8,0" Appearance="Danger" Click="ClearButton_Click" />
            <ui:Button Content="Refresh" Icon="ArrowRepeatAll24" Padding="12,6" Margin="0,0,8,0" Click="RefreshButton_Click" />
            <ui:Button Content="Close" Appearance="Primary" Padding="16,6" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</base:WpfUiWindow>
